{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "policy.v0",
  "type": "object",
  "required": ["policy_id", "policy_version", "rules"],
  "properties": {
    "policy_id": { "type": "string" },
    "policy_version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "requires": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "then"],
        "properties": {
          "name": { "type": "string" },
          "default": { "type": "boolean" },
          "when": { "type": "object" },
          "then": {
            "type": "object",
            "required": ["decision_band"],
            "properties": {
              "decision_band": {
                "type": "string",
                "enum": ["PROCEED", "PROCEED_WITH_RISK", "ESCALATE", "BLOCK"]
              },
              "risk_code": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
