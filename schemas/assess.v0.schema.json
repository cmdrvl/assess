{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "assess.v0",
  "type": "object",
  "required": ["tool", "version"],
  "properties": {
    "tool": { "const": "assess" },
    "version": { "const": "assess.v0" },
    "decision_band": {
      "type": ["string", "null"],
      "enum": ["PROCEED", "PROCEED_WITH_RISK", "ESCALATE", "BLOCK", null]
    },
    "policy": {
      "type": ["object", "null"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "integer" },
        "sha256": { "type": "string" }
      },
      "required": ["id", "version", "sha256"]
    },
    "matched_rule": { "type": ["string", "null"] },
    "required_tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "observed_tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_factors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "source_tool": { "type": "string" },
          "detail": { "type": "string" }
        },
        "required": ["code"]
      }
    },
    "epistemic_basis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "artifact": { "type": "string" },
          "tool": { "type": "string" },
          "version": { "type": "string" },
          "outcome": { "type": ["string", "null"] },
          "policy_signals": { "type": "object" },
          "refusal": {
            "type": ["object", "null"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        },
        "required": ["artifact", "tool", "version"]
      }
    },
    "refusal": {
      "type": ["object", "null"],
      "required": ["code", "message", "detail", "next_command"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "E_BAD_POLICY",
            "E_AMBIGUOUS_POLICY",
            "E_UNKNOWN_POLICY",
            "E_BAD_ARTIFACT",
            "E_DUPLICATE_TOOL",
            "E_INCOMPLETE_BASIS",
            "E_MISSING_RULE"
          ]
        },
        "message": { "type": "string" },
        "detail": { "type": "object" },
        "next_command": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
